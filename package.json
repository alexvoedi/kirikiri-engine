{
  "name": "kirikiri-engine",
  "type": "module",
  "version": "0.2.0-beta.0",
  "private": false,
  "packageManager": "pnpm@11.5.2",
  "description": "a javascript reimplementation for the kirikiri visual novel engine",
  "author": {
    "name": "Alexander Vödisch"
  },
  "license": "MIT",
  "keywords": [
    "game",
    "visual novel",
    "engine"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json",
    "./cli": {
      "types": "./dist/cli.d.mts",
      "import": "./dist/cli.mjs",
      "require": {
        "types": "./dist/cli.d.cts",
        "default": "./dist/cli.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "kiri-cli": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "serve": "vite",
    "dev": "tsdown --watch ./src",
    "build": "tsdown",
    "lint": "eslint . --cache",
    "lint:ci": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --run --coverage",
    "test:watch": "CI=0 FORCE_COLOR=1 vitest --watch --coverage",
    "test:ui": "vitest --ui",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "knip": "knip --cache",
    "knip:ci": "knip --production",
    "check": "nx run-many -t lint test typecheck convert knip",
    "check:watch": "pnpm check && nx watch --all -- pnpm check"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "es-toolkit": "^1.47.0",
    "pixi.js": "^8.19.0",
    "ses": "^2.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@nx/eslint": "22.7.5",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.16.0",
    "nano-staged": "^1.0.0",
    "nx": "22.7.5",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "nano-staged": {
    "*.{ts,json,html}": "eslint --fix"
  },
  "nx": {}
}
